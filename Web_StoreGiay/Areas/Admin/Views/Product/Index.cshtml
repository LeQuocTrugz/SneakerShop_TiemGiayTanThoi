@model IEnumerable<Web_StoreGiay.Models.Product>

@{
    ViewData["Title"] = "Danh Sách Sản Phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="my-4">Quản Lý Sản Phẩm</h2>

<a class="btn btn-success mb-3" asp-area="Admin" asp-controller="Product" asp-action="Add">
    <i class="fas fa-plus"></i> Thêm sản phẩm
</a>

<table id="productsTable" class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Tên Sản Phẩm</th>
            <th>Giá</th>
            <th style="width: 300px">Mô Tả</th>
            <th>Ảnh Sản Phẩm</th>
            <th>Hãng</th>
            <th style="width: 200px">Chức Năng</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <td>@product.Name</td>
                <td>@String.Format("{0:N0} đ", product.Price)</td>
                <td class="text-truncate" style="max-width: 300px;">
                    @if (!string.IsNullOrEmpty(product.Description) && product.Description.Length > 50)
                    {
                        @Html.Raw(product.Description.Substring(0, 70) + "...")
                    }
                    else
                    {
                        @Html.Raw(product.Description)
                    }
                </td>

                <td>
                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                    {
                        <img src="@product.ImageUrl" alt="Ảnh sản phẩm" width="100" class="img-thumbnail" />
                    }
                    else
                    {
                        <img src="https://via.placeholder.com/100" alt="Không có ảnh" width="100" class="img-thumbnail" />
                    }
                </td>
                <td>@product.Category?.Name</td>
                <td class="text-nowrap">
                    <a class="btn btn-info btn-sm" asp-area="Admin" asp-controller="Product" asp-action="Display" asp-route-id="@product.Id">
                        <i class="fas fa-eye"></i> Chi tiết
                    </a>
                    <a class="btn btn-warning btn-sm" asp-area="Admin" asp-controller="Product" asp-action="Update" asp-route-id="@product.Id">
                        <i class="fas fa-edit"></i> Sửa
                    </a>
                    <a class="btn btn-danger btn-sm" asp-area="Admin" asp-controller="Product" asp-action="Delete" asp-route-id="@product.Id">
                        <i class="fas fa-trash"></i> Xóa
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
    <link href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css" rel="stylesheet" />

    <script>
        $(document).ready(function () {
            $('#productsTable').DataTable({
                language: {
                    search: "Tìm kiếm:",
                    lengthMenu: "Hiển thị _MENU_ sản phẩm",
                    info: "Hiển thị _START_ đến _END_ trong _TOTAL_ sản phẩm",
                    paginate: {
                        previous: "Trước",
                        next: "Sau"
                    }
                },
                columnDefs: [
                    { orderable: false, targets: [2, 3, 5] }
                ],
                lengthMenu: [5, 10, 25, 50]
            });
        });
    </script>
}
