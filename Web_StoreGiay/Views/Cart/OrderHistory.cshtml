@model IEnumerable<Web_StoreGiay.Models.Order>

<h2>Lịch sử đơn hàng</h2>

<table class="table">
    <thead>
        <tr>
            <th>ID Đơn Hàng</th>
            <th>Ngày đặt</th>
            <th>Tổng giá trị</th>
            <th>Trạng thái</th>
            <th>Chi tiết</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.Id</td>
                <td>@order.OrderDate.ToString("dd/MM/yyyy")</td>
                <td>@order.TotalPrice.ToString("N0") VND</td>
                <td>@order.Status</td>
                <td>
                    <a href="@Url.Action("OrderDetails", "Cart", new { id = order.Id })" class="btn btn-info">Xem chi tiết</a>
                </td>
            </tr>
        }
    </tbody>
</table>
