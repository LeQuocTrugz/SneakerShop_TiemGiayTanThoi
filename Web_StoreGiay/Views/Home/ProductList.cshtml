@model IEnumerable<Web_StoreGiay.Models.Product>

@{
    // ViewData["Title"] = "Danh sách sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div>
    <h3 class="section-title-1">@ViewData["Title"]</h3>
</div>
<section class="container-fluid">
    <div class="row">
        <!-- Bộ lọc bên trái (30%) -->
        <div class="col-md-3">
            <div class="filter-section shadow-sm p-4 mb-5 bg-light rounded">
                <h5 class="mb-3">Lọc theo khoảng giá</h5>
                <div class="price-filter">
                    <div>
                        <input type="radio" id="price1" name="price" value="1000000" />
                        <label for="price1">Dưới 1.000.000₫</label><br>
                        <input type="radio" id="price2" name="price" value="2000000" />
                        <label for="price2">1.000.000₫ - 2.000.000₫</label><br>
                        <input type="radio" id="price3" name="price" value="3000000" />
                        <label for="price3">2.000.000₫ - 3.000.000₫</label><br>
                        <input type="radio" id="price4" name="price" value="5000000" />
                        <label for="price4">3.000.000₫ - 5.000.000₫</label><br>
                    </div>
                    <button class="btn btn-primary w-100" onclick="applyFilter()">Áp dụng</button>
                </div>

                <hr />

                <h5 class="mb-3">Lọc theo size</h5>
                <div class="size-filter">
                    @foreach (var size in ViewBag.Sizes)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" value="@size.Id" data-size-id="@size.Id">
                            <label class="form-check-label" for="@size.Id">@size.SizeNumber </label>
                        </div>
                    }
                    <button class="btn btn-primary w-100" onclick="applyFilter()">Áp dụng</button>
                </div>

                <hr />

                <h5 class="mb-3">Lọc theo thương hiệu</h5>
                <div class="brand-filter">
                    @foreach (var brand in ViewBag.Categories)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" value="@brand.Id" id="@brand.Id">
                            <label class="form-check-label" for="@brand.Id">@brand.Name</label>
                        </div>
                    }
                    <button class="btn btn-primary w-100" onclick="applyFilter()">Áp dụng</button>
                </div>
            </div>
        </div>

        <!-- Danh sách sản phẩm bên phải (70%) -->
        <div class="col-md-9">
            <div class="product-section mb-4">
                <div class="row mb-4">
                    @foreach (var product in Model)
                    {
                        <div class="col-md-4 mb-4">
                            <div class=" product-item"
                                 data-price="@product.Price" data-size="@string.Join(",", product.ProductSizes?.Select(ps => ps.SizeId.ToString()) ?? new List<string>())" data-brand="@product.CategoryId">
                                <a href="@Url.Action("Display", "Home", new { id = product.Id })" class="text-decoration-none text-dark">
                                    <div class="card product shadow-sm">
                                        <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name">
                                        <div class="card-body">
                                            <h5 class="card-title">@product.Name </h5>
                                            @if (product.DiscountPrice.HasValue)
                                            {
                                                <span class="text-danger fw-bold">@product.DiscountPrice.Value.ToString("N0") VND</span>
                                                <span class="text-muted" style="text-decoration: line-through;">@product.Price.ToString("N0")</span>
                                            }
                                            else
                                            {
                                                <span class="text-danger fw-bold">@product.Price.ToString("N0") VND</span>
                                            }
                                        </div>
                                    </div>
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
                document.querySelectorAll('.filter-price, .filter-size, .filter-brand').forEach(function(filter) {
            filter.addEventListener('change', filterProducts);
        });

        function filterProducts() {
            var selectedPrice = document.querySelector('input[name="price"]:checked')?.value;
            var selectedSizes = Array.from(document.querySelectorAll('.filter-size:checked')).map(el => el.value);
            var selectedBrands = Array.from(document.querySelectorAll('.filter-brand:checked')).map(el => el.value);

            document.querySelectorAll('.product-item').forEach(function(product) {
                var productPrice = product.getAttribute('data-price');
                var productSizes = product.getAttribute('data-size').split(',');
                var productBrand = product.getAttribute('data-brand');

                // Kiểm tra điều kiện cho bộ lọc
                var priceMatch = !selectedPrice || productPrice <= selectedPrice;
                var sizeMatch = selectedSizes.length === 0 || selectedSizes.some(size => productSizes.includes(size));
                var brandMatch = selectedBrands.length === 0 || selectedBrands.includes(productBrand);

                // Ẩn hoặc hiển thị sản phẩm
                if (priceMatch && sizeMatch && brandMatch) {
                    product.style.display = 'block';
                } else {
                    product.style.display = 'none';
                }
            });
        }
    </script>
}
