@model IEnumerable<Web_StoreGiay.Models.Product>

@{
    ViewData["Title"] = "IndexUser";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="promo-section container-fluid d-flex justify-content-center">
    <div id="carouselExampleIndicators" class="carousel slide col-md-8" data-bs-ride="carousel">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <a href="@Url.Action("Search", "Home", new { keyword = "Nike" })">
                <img src="~/Images/Carousle_Nike.png" class="d-block w-100 img-fluid" alt="Nike">
                </a>
            </div>
            <div class="carousel-item">
                <a href="@Url.Action("Search", "Home", new { keyword = "Adidas" })">
                <img src="~/Images/Carousel_Adidas.png" class="d-block w-100 img-fluid" alt="Adidas">
                </a>
            </div>
            <div class="carousel-item">
                <a href="https://www.facebook.com/permalink.php?story_fbid=pfbid02AsN5JAA3DWeerndXRZpst1gjmX8nNQ27XfVRBQVGXDtDShb9ojLEqQEuNx8UbiKtl&id=100088578951849">
                <img src="~/Images/Carousel_CTV.png" class="d-block w-100 img-fluid" alt="Converse">
                </a>
            </div>
            <!-- Thêm chính sách vào Carousel -->
            <div class="carousel-item">
                <img src="~/Images/chính sách.png" class="d-block w-100 img-fluid policy-slide" alt="Chính sách">
            </div>
        </div>

        <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>
</section>

<!-- Sản phẩm hiển thị theo từng nhóm -->
<!-- Danh sách sản phẩm -->
<section class="product-section mb-4">
    <div class="container" style="max-width: 90%; margin: 0 auto;">
        <div class="d-flex justify-content-between align-items-center">
            <h3 class="section-title">
                Sản phẩm mới           
            </h3>
            <h3><a href="@Url.Action("AllProducts","Home")" class="see-more ml-auto">Xem thêm...</a> </h3>
        </div>
        <hr class="section-divider" />
        <div class="row mb-4">
            @foreach (var product in Model.Take(4))
            {
                <div class="col-md-3">
                    <a href="@Url.Action("Display", "Home", new { id = product.Id })" class="text-decoration-none text-dark">
                        <div class="card product mb-4 shadow-sm">
                            <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name">
                            <div class="card-body">
                                <h5 class="card-title">@product.Name </h5>
                                @if (product.DiscountPrice.HasValue)
                                {
                                    <span class="text-danger fw-bold">@product.DiscountPrice.Value.ToString("N0") VND</span>
                                    <span class="text-muted" style="text-decoration: line-through;">@product.Price.ToString("N0")</span>
                                }
                                else
                                { 
                                    <span class="text-danger fw-bold">@product.Price.ToString("N0") VND</span>
                                }
                            </div>
				        </div>
			        </a>
		        </div>
            }
        </div>
    </div>
</section>

<!-- Danh sách giày nam -->
